{
  "name": "@turbopush/turbopush-expo-plugin",
  "version": "1.0.2",
  "main": "./app.plugin.js",
  "license": "MIT",
  "files": [
    "app.plugin.js",
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turbopushdev/turbopush-expo-plugin.git"
  },
  "scripts": {
    "build": "expo-module tsc",
    "run:all": "bash -c 'for dir in examples/expo*/; do (echo \"[$dir] running $1\" && yarn --cwd \"$dir\" \"$1\") & done; wait' --",
    "prebuild:all": "yes | yarn run:all prebuild --clean",
    "install:all": "yarn run:all install",
    "prepare": "yarn build",
    "deps:update": "ncu --filter '@turbopush/*' -u --packageFile 'examples/*/package.json'",
    "e2e": "bash scripts/run_e2e.sh",
    "e2e:all": "bash scripts/run_e2e_all.sh",
    "e2e:all:ios": "bash scripts/run_e2e_all.sh ios",
    "e2e:all:android": "bash scripts/run_e2e_all.sh android"
  },
  "keywords": [
    "turbopush",
    "expo",
    "plugin",
    "codepush",
    "expo-codepush-plugin",
    "react-native-code-push"
  ],
  "bugs": {
    "url": "https://github.com/turbopushdev/turbopush-expo-plugin/issues"
  },
  "homepage": "https://github.com/turbopushdev/turbopush-expo-plugin#readme",
  "devDependencies": {
    "@expo/config-plugins": "~9.0.0",
    "expo-module-scripts": "^3.5.2",
    "npm-check-updates": "^22.2.0",
    "typescript": "~5.3.3"
  },
  "packageManager": "yarn@4.15.0"
}