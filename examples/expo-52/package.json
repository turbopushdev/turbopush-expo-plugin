{
  "name": "expo-52",
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "build:plugin": "yarn --cwd ../.. build",
    "prebuild": "yarn build:plugin && expo prebuild",
    "start": "expo start",
    "android": "yarn prebuild && expo run:android",
    "ios": "yarn prebuild && expo run:ios",
    "web": "expo start --web",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy",
    "codepush:normal": "yarn turbopush release-expo testing-expo-52 ios 1.0.2 -d prod-ios -r 100",
    "codepush:android:normal": "yarn turbopush release-expo testing-expo-52 android 1.0.2 -d prod-android -r 100",
    "codepush:android": "yarn codepush:android:normal --mandatory",
    "codepush": "yarn codepush:normal --mandatory"
  },
  "dependencies": {
    "@expo/config-plugins": "~9.0.0",
    "@repo/shared": "portal:../shared",
    "@turbopush/react-native-code-push": "^10.2.6",
    "expo": "~52.0.0",
    "expo-application": "~6.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.21",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "nativewind": "^4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "^0.19.13",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@turbopush/cli": "^1.0.27",
    "@types/react": "~18.3.12",
    "rimraf": "^6.0.1",
    "typescript": "~5.3.3"
  },
  "private": true
}